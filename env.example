# ── JARVIS Voice (ElevenLabs) ──
# Sign up free at https://elevenlabs.io → Profile → API Key
# Free tier gives 10,000 characters/month — plenty for demos
VITE_ELEVENLABS_API_KEY=

# (Optional) Change JARVIS voice. Some good options:
#   onwK4e9ZLuTAKqWW03F9  → Daniel (British, calm — default)
#   pNInz6obpgDQGcFmaJgB  → Adam (deep, American)
#   ErXwobaYiN019PkySvjV  → Antoni (warm, younger)
#   ZQe5CZNOzWyzPSCn5a3c  → James (authoritative, British)
#   TX3LPaxmHKxFdv7VOQHJ  → Liam (American, natural)
# VITE_ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
